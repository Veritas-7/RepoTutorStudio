{
  "name": "repotutor-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "build": "pnpm -r --sort build",
    "typecheck": "pnpm -r --sort typecheck",
    "test": "vitest run",
    "lint": "pnpm typecheck",
    "doctor": "pnpm --filter @repotutor/cli dev -- doctor",
    "verify:learning-targets": "pnpm --filter @repotutor/shared build && node scripts/verify-learning-targets.mjs",
    "audit:brief": "node scripts/compliance-audit.mjs --iterations 13"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.15",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "zod": "^4.1.13"
  }
}
