{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RepoTutor Studio",
  "version": "0.1.0",
  "identifier": "com.veritas.repotutor-studio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RepoTutor Studio",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
